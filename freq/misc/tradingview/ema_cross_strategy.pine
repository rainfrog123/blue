//@version=6
indicator("EMA Cross Indicator", overlay=true)

// Input parameters
fast_period = input.int(5, title="Fast EMA Period")
slow_period = input.int(20, title="Slow EMA Period")

// Calculate EMAs
fast_ema = ta.ema(close, fast_period)
slow_ema = ta.ema(close, slow_period)

// Plot EMAs
plot(fast_ema, color=color.blue, title="Fast EMA")
plot(slow_ema, color=color.red, title="Slow EMA")

// Detect crossovers
long_signal = ta.crossover(fast_ema, slow_ema)
short_signal = ta.crossunder(fast_ema, slow_ema)

// Plot signals
plotshape(long_signal, location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small, title="Long Signal")
plotshape(short_signal, location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small, title="Short Signal")

