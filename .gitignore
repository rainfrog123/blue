# ─────────────────────────────────────────────────────────────────────────────
# Sensitive credentials - never commit
# ─────────────────────────────────────────────────────────────────────────────
**/cred.json
**/.env
**/auth.json
**/id_rsa
**/id_ed25519
**/*.pem

# Tinder data files with session tokens
web/apps/tinder/data/*.json

# ─────────────────────────────────────────────────────────────────────────────
# Freqtrade
# ─────────────────────────────────────────────────────────────────────────────
backtest-result*
*result.json
last_result.json
trading/user_data/backtest_results/
trading/user_data/logs/
trading/user_data/plot/
trading/user_data/ml_datasets/

# ─────────────────────────────────────────────────────────────────────────────
# ML datasets / models (large binaries)
# ─────────────────────────────────────────────────────────────────────────────
*.feather
*.npy
*.pkl
*.pt
trading/ml/processed/

# ─────────────────────────────────────────────────────────────────────────────
# TradingView collector data
# ─────────────────────────────────────────────────────────────────────────────
trading/tools/realtime/tradingview/data/
*.db

# ─────────────────────────────────────────────────────────────────────────────
# AWS / Cloud provider output
# ─────────────────────────────────────────────────────────────────────────────
infra/cloud/aws/nuke-output*.txt
infra/cloud/aws/cloud-nuke
tradesv3.sqlite*

# ─────────────────────────────────────────────────────────────────────────────
# Cache files
# ─────────────────────────────────────────────────────────────────────────────
*.cache
*.log
*.har
__pycache__/
*.pyc
*.pyo
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.wrangler/
dist/

# ─────────────────────────────────────────────────────────────────────────────
# Temporary / OS
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
.DS_Store
web/patchright/test/
web/patchright/test_report.json

# ─────────────────────────────────────────────────────────────────────────────
# iOS app packages
# ─────────────────────────────────────────────────────────────────────────────
*.ipa
*.tipa

# Windows-reserved filename not stageable on Windows
infra/cloud/digi/nul
